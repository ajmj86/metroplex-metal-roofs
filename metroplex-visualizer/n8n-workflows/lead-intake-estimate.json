    {
      "id": "build_contact_payload",
      "name": "Build Contact Payload (Estimate Scoped, Filter Nulls)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1180, 220],
      "notes": "SCOPED WRITE FIX: allow-list only includes firstName/lastName/email/phone/address1 + lead_source/property_address/estimated_roof_size/estimate_range. current_roof_type, selected_roof_type, project_reason, insurance_claim_status, homeowner_timeline are never read from the payload — structurally impossible to write, even as null. Uses named node selectors per Workflow 1 lessons learned, never $input.first().json.",
      "parameters": {
        "jsCode": "const webhookData = $(\"Webhook – Lead Intake (Estimate)\").first().json.body;\nconst configData = $(\"Config – GHL IDs\").first().json;\n\nconst contact = webhookData.contact || {};\nconst fields = webhookData.fields || {};\n\n// Scoped-write allow-list — estimate tool must NEVER write roof-type fields.\nconst FIELD_IDS = {\n  lead_source: 'pOqyjdxOHg67C4JWdkaG',\n  property_address: 'acFCeylcy8uhep3stymL',\n  estimated_roof_size: 'S3E1cQMFQ2vD2Ec1nSAR',\n  estimate_range: 'cEjn1x0nid6taqIaQxKt',\n};\n\nconst isEmpty = (v) => v === null || v === undefined || v === '';\n\nconst contactFields = {};\nfor (const key of ['firstName', 'lastName', 'email', 'phone', 'address1']) {\n  if (!isEmpty(contact[key])) contactFields[key] = contact[key];\n}\n\nconst customFields = [];\nfor (const [key, id] of Object.entries(FIELD_IDS)) {\n  if (!isEmpty(fields[key])) customFields.push({ id, value: fields[key] });\n}\nif (customFields.length) contactFields.customFields = customFields;\ncontactFields.tags = Array.isArray(webhookData.tags) && webhookData.tags.length ? webhookData.tags : ['Estimate Tool'];\n\nconst contactPayloadCreate = { ...contactFields, locationId: configData.locationId };\nconst contactPayloadUpdate = { ...contactFields };\n\nreturn [{\n  json: {\n    email: contact.email,\n    contactPayloadCreate,\n    contactPayloadUpdate,\n    rawFields: fields,\n    locationId: configData.locationId,\n    pipelineId: configData.pipelineId,\n    stageId: configData.stageId,\n    firstName: contact.firstName || '',\n    lastName: contact.lastName || '',\n    phone: contact.phone || '',\n    source: webhookData.source || 'estimate',\n  },\n}];"
      }
    },
