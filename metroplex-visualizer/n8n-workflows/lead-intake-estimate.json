    {
      "id": "check_existing_opportunity",
      "name": "Check Existing Opportunity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 220],
      "notes": "Dedup + stage-guard logic: if an opportunity already exists for this contact, never create a duplicate. Only re-affirm the stage if it's still sitting at Visualizer/Estimate Submitted (stage 1) — if sales has already moved it forward (Contacted, Appointment Set, etc.), leave it alone so an estimate-tool resubmission can't knock it backward.",
      "parameters": {
        "jsCode": "const search = $(\"Search Opportunities For Contact\").first().json;\nconst cfg = $(\"Config – GHL IDs\").first().json;\nconst built = $(\"Build Contact Payload (Estimate Scoped, Filter Nulls)\").first().json;\nconst normalized = $(\"Normalize Contact Result\").first().json;\n\nconst opportunities = Array.isArray(search.opportunities) ? search.opportunities : [];\nconst existing = opportunities[0] || null;\n\nlet opportunityAction = 'create';\nlet opportunityId = null;\n\nif (existing && existing.id) {\n  opportunityId = existing.id;\n  opportunityAction = (existing.pipelineStageId === cfg.stageId) ? 'updateStage' : 'noop';\n}\n\nreturn [{\n  json: {\n    contactId: normalized.contactId,\n    firstName: built.firstName,\n    lastName: built.lastName,\n    phone: built.phone,\n    source: built.source,\n    locationId: built.locationId,\n    pipelineId: built.pipelineId,\n    stageId: built.stageId,\n    opportunityAction,\n    opportunityId,\n  },\n}];"
      }
    },
