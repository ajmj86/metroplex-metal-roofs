# Google Cloud — enable these three APIs in Google Cloud Console:
#   Street View Static API
#   Maps Static API
#   Places API  ← required for address autocomplete
#
# Both variables below use the same key value.
# GOOGLE_MAPS_API_KEY   — server-side only (API routes)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY — exposed to the browser for Places Autocomplete
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Solar API — separate key from GOOGLE_MAPS_API_KEY, must have the
# Solar API enabled in Google Cloud Console. Server-side only, used by
# src/app/api/estimate/route.ts to compute roof size for pricing.
GOOGLE_SOLAR_API_KEY=your_google_solar_api_key_here

# OpenAI — requires access to gpt-image-1 (images.edit endpoint)
OPENAI_API_KEY=your_openai_api_key_here

# n8n Lead Intake (Visualizer) workflow webhook
# Server-side only (no NEXT_PUBLIC_ prefix) — called from app/api/lead-intake/route.ts,
# never exposed to the browser. n8n owns all GHL contact/opportunity/tag writes.
N8N_WEBHOOK_VISUALIZER=https://n8n.metroplexmetalroofs.com/webhook/lead-intake-visualizer

# n8n Lead Intake (Estimate Tool) workflow webhook
# Server-side only — called from src/app/api/estimate/route.ts.
N8N_WEBHOOK_ESTIMATE=https://n8n.metroplexmetalroofs.com/webhook/lead-intake-estimate
