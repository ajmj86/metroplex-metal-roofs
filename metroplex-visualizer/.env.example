# Google Cloud — enable these three APIs in Google Cloud Console:
#   Street View Static API
#   Maps Static API
#   Places API  ← required for address autocomplete
#
# Both variables below use the same key value.
# GOOGLE_MAPS_API_KEY   — server-side only (API routes)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY — exposed to the browser for Places Autocomplete
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenAI — requires access to gpt-image-1 (images.edit endpoint)
OPENAI_API_KEY=your_openai_api_key_here

# GoHighLevel webhook URL for lead capture
# Exposed to the browser — keep this to a webhook-only URL with no admin access
NEXT_PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID/webhook-trigger/YOUR_TRIGGER_ID
